{
  "$schema": "statusline/component@1",
  "id": "burn",
  "name": "Usage Burn Rate",
  "version": "0.1.0",
  "author": { "github": "zyx1121" },
  "description": "How fast the 5h usage budget is climbing (%/h), sampled over ≥60s windows per session.",
  "type": "segment",
  "runtime": "bash",
  "render": { "entry": "render.sh" },
  "inputs": ["rate_limits.five_hour"],
  "requires": { "bin": ["awk"] },
  "config": {},
  "placement": { "slot": "row2", "order": 30 },
  "capabilities": { "fs_write": ["$STATE"], "stdin_fields": ["rate_limits.five_hour", "session_id"] }
}
