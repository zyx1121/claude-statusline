{
  "$schema": "statusline/component@1",
  "id": "news",
  "name": "News Ticker",
  "version": "0.1.0",
  "author": { "github": "zyx1121" },
  "description": "Right-scrolling Google News headline ticker (zh-TW RSS, keyless).",
  "type": "line",
  "runtime": "python3",
  "render": { "entry": "render.py", "ttl": 1 },
  "fetch": { "entry": "render.py", "args": ["--fetch"], "ttl": 3600, "self_managed": true },
  "inputs": ["session_id"],
  "requires": { "bin": ["python3"], "network": ["news.google.com"] },
  "config": {
    "schema": {
      "topics": {
        "type": "array",
        "default": ["top", "台灣", "國際", "科技"],
        "desc": "Topics. top=Google News top stories, anything else=a search keyword."
      }
    },
    "file": "topics.default"
  },
  "placement": { "slot": "top", "order": 10 },
  "capabilities": {
    "network": ["news.google.com"],
    "exec": false,
    "fs_write": ["$STATE_DIR"],
    "stdin_fields": []
  }
}
